              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Response contains requestId and status SUCCESS', function () { pm.expect(json.requestId).to.exist; pm.expect(json.status).to.eql('SUCCESS'); });",
                  "pm.test('Response includes detections array', function () { pm.expect(json.detections).to.be.an('array'); });"
                ]
