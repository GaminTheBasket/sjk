                  "pm.test('Response contains requestId', function () { pm.expect(json.requestId).to.eql(pm.environment.get('asyncRequestId')); });",
                  "pm.test('Response status is PROCESSING or SUCCESS', function () { pm.expect(json.status).to.be.oneOf(['PROCESSING', 'SUCCESS']); });"
