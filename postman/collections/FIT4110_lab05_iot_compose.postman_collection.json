                  "pm.test('Status code is 202', function () { pm.response.to.have.status(202); });",
                  "pm.test('Location header is present', function () { pm.expect(pm.response.headers.has('Location')).to.be.true; });",
                  "const json = pm.response.json();",
                  "pm.test('Response status is PROCESSING', function () { pm.expect(json.status).to.eql('PROCESSING'); });",
                  "if (json.requestId) { pm.environment.set('asyncRequestId', json.requestId); }"
                ]
              }
            }
