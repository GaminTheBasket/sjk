  "item": [
    {
      "name": "01_System",
      "item": [
        {
          "name": "GET /health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Response provides service name and time', function () { pm.expect(json.service).to.eql('ai-vision-service'); pm.expect(json).to.have.property('time'); });"
                ]
              }
            }
          ]
        }
      ]
    },
