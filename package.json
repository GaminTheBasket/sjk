{
  "name": "fit4110-lab05-docker-compose-readiness",
  "version": "0.1.0",
  "description": "FIT4110 Lab 05 - Smart Campus API contract and Docker Compose readiness",
  "private": true,
  "scripts": {
    "mock:api": "prism mock openapi.yaml --host 0.0.0.0 --port 4010",
    "lint:openapi": "npx spectral lint --ruleset .spectral.yml openapi.yaml",
    "lint:contracts": "npx spectral lint --ruleset .spectral.yml contracts/*.yaml",
    "test:compose": "newman run postman/collections/FIT4110_lab05_iot_compose.postman_collection.json --environment postman/environments/FIT4110_lab05_local.postman_environment.json --reporters cli,json,htmlextra --reporter-json-export reports/newman-lab05-compose.json --reporter-htmlextra-export reports/newman-lab05-compose.html"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.10.0",
    "@stoplight/spectral-cli": "^6.13.1",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "wait-on": "^8.0.1"
  }
}